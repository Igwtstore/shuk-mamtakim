{
  "rewrites": [
    { "source": "/tienda", "destination": "/index.html" },
    { "source": "/mayorista", "destination": "/index.html" },
    { "source": "/candyshop/meir", "destination": "/tienda.html?kid=meir" },
    { "source": "/candyshop/iosi", "destination": "/tienda.html?kid=iosi" }
  ],
  "headers": [
    {
      "source": "/(.*\\.html)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    },
    {
      "source": "/sw.js",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    }
  ]
}
